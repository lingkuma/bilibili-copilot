{
  "name": "bilibili-copilot",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "description": "Bilibili AI video summary browser extension",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "site:build": "node site/build.mjs",
    "zip": "wxt zip",
    "compile": "wxt compile",
    "check": "wxt prepare && svelte-check --tsconfig ./tsconfig.json"
  },
  "dependencies": {
    "@wxt-dev/module-svelte": "^2.0.4",
    "svelte": "^5.0.0",
    "wxt": "^0.20.0"
  },
  "devDependencies": {
    "@tsconfig/svelte": "^5.0.4",
    "svelte-check": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
